# The model size of OpenAI Whisper (see https://github.com/openai/whisper#available-models-and-languages)
WHISPER_MODEL_SIZE=medium

# LLM Providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
YOUTUBE_DATA_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# The AI Model to use throughout the app
LLM=google-gla:gemini-3-flash-preview

# Prevent tasks from sitting in queued forever if worker is down
QUEUED_TASK_TIMEOUT_SECONDS=180

# YouTube metadata lookup provider: `yt_dlp` or `youtube_data_api`
YOUTUBE_METADATA_PROVIDER=yt_dlp

# Processing defaults
DEFAULT_PROCESSING_MODE=fast
FAST_MODE_MAX_CLIPS=4
FAST_MODE_TRANSCRIPT_MODEL=nano

# Good for speed optimizations
COMPOSE_BAKE=true

# DB
POSTGRES_DB=supoclip
POSTGRES_USER=supoclip
POSTGRES_PASSWORD=supoclip_password

ASSEMBLY_AI_API_KEY=

CORS_ORIGINS=http://localhost:3000,http://sp.localhost:3000
